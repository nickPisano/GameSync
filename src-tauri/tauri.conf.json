{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GameSync",
  "version": "0.1.3",
  "identifier": "com.gamesync.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GameSync",
        "width": 1040,
        "height": 740,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Game save backup & sync",
    "longDescription": "Safe, versioned backup and cross-device sync for game saves that lack reliable Steam Cloud."
  }
}
